{
    "compilerOptions": {
        "paths": {
            "@/*": [
                "./src/*"
            ],
            "@bindings/*": [
                "./bindings/*"
            ]
        }
    },
    "include": [
        "src/**/*.d.ts",
        "src/**/*.ts",
        "src/**/*.svelte",
        "vite.config.ts",
        "bindings"
    ]
}
